diff --git a/src/sysconf.cpp b/src/sysconf.cpp
index a6b7d28..eb80ebe 100644
--- a/src/sysconf.cpp
+++ b/src/sysconf.cpp
@@ -2,8 +2,23 @@
 
 #include <unistd.h>
 #include <stdexcept>
+#include <cstdlib>
 
 long shim::sysconf(int name) {
+    // 0x60/0x61 = bionic _SC_NPROCESSORS_CONF/ONLN. MCPE_FAKE_NPROC lets the
+    // game see fewer cores so it sizes its worker pools smaller, leaving CPU
+    // headroom for the render/main threads (4x Cortex-A53 chunk-burst fix).
+    if(name == 0x0060 || name == 0x0061) {
+        static long fake = []() -> long {
+            const char *value = std::getenv("MCPE_FAKE_NPROC");
+            if(value == nullptr || *value == '\0')
+                return 0;
+            long parsed = std::strtol(value, nullptr, 10);
+            return (parsed >= 1 && parsed <= 16) ? parsed : 0;
+        }();
+        if(fake > 0)
+            return fake;
+    }
     return ::sysconf(bionic::to_host_sysconf_id(name));
 }
 
