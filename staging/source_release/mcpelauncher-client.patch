+static void parseCpuList(const char *value, cpu_set_t *set) {
+    CPU_ZERO(set);
+    const char *p = value;
+    while(*p) {
+        char *end = nullptr;
+        long a = std::strtol(p, &end, 10);
+        if(end == p)
+            break;
+        long b = a;
+        p = end;
+        if(*p == '-') {
+            b = std::strtol(p + 1, &end, 10);
+            if(end == p + 1)
+                break;
+            p = end;
+        }
+        for(long c = a; c <= b; c++)
+            if(c >= 0 && c < CPU_SETSIZE)
+                CPU_SET((int)c, set);
+        if(*p == ',')
+            p++;
+    }
+}
