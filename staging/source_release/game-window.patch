 void EGLUTWindow::makeCurrent(bool active) {
+    const char* crustyBridgeEnv = std::getenv("GAMEWINDOW_EGLUT_CRUSTY_CONTEXT");
+    if (crustyBridgeEnv && *crustyBridgeEnv && strcmp(crustyBridgeEnv, "0") != 0) {
+        // Crusty's public eglMakeCurrent is intentionally a success-returning
+        // stub for application callers. Transfer its real SDL context using
+        // the private handle slots from Westonpack 0.2.7.1's aarch64 crusty
+        // X11-EGL build.
+        using MakeCurrent = int (*)(void *, void *);
+        using GetError = const char *(*)();
+        static auto makeBackendCurrent = reinterpret_cast<MakeCurrent>(
+            dlsym(RTLD_DEFAULT, "_SDL_GL_MakeCurrent"));
+        static auto getBackendError = reinterpret_cast<GetError>(
+            dlsym(RTLD_DEFAULT, "_SDL_GetError"));
+
+        Dl_info info{};
+        bool crustyPresent = makeBackendCurrent &&
+            dladdr(reinterpret_cast<void *>(makeBackendCurrent), &info) &&
+            info.dli_fbase;
+        if (!crustyPresent) {
+            // No crusty in this process (e.g. Mesa/Panfrost device where
+            // westonwrap bypasses the shim) -> use the native EGL path.
+            static bool warned = false;
+            if (!warned) {
+                fprintf(stderr, "EGLUT crusty context bridge unavailable; "
+                                "using native EGL context path\n");
+                warned = true;
+            }
+        } else {
+
+        constexpr uintptr_t SDL_WINDOW_SLOT = 0x1e978;
+        constexpr uintptr_t SDL_CONTEXT_SLOT = 0x1e980;
+        auto base = reinterpret_cast<uintptr_t>(info.dli_fbase);
+        auto windowSlot = reinterpret_cast<void **>(base + SDL_WINDOW_SLOT);
+        auto contextSlot = reinterpret_cast<void **>(base + SDL_CONTEXT_SLOT);
+        void *window = *windowSlot;
+        void *context = active ? *contextSlot : nullptr;
+
+        if (!window || (active && !context)) {
+            fprintf(stderr, "EGLUT crusty context handles are unavailable\n");
+            return;
+        }
+
+        int result = makeBackendCurrent(window, context);
+        if (result != 0)
+            fprintf(stderr, "EGLUT crusty context bridge failed: %d (%s)\n",
+                    result, getBackendError ? getBackendError() : "unknown SDL error");
+        return;
+        }
+    }
+
 #ifdef GAMEWINDOW_X11_LOCK
     std::lock_guard<std::recursive_mutex> lock(x11_sync);
 #endif
